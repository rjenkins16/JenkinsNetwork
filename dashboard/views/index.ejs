<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JenkinsNetwork Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background-color: #121212;
            color: #e0e0e0;
            padding: 20px;
        }
        
        .container {
            max-width: 1400px;
            margin: 0 auto;
        }
        
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            border-bottom: 1px solid #333;
            margin-bottom: 30px;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .logo i {
            font-size: 2.5rem;
            color: #4fc3f7;
        }
        
        .logo h1 {
            font-size: 2rem;
            font-weight: 600;
        }
        
        .status-bar {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .status-card {
            background: #1e1e1e;
            border-radius: 10px;
            padding: 20px;
            flex: 1;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        }
        
        .status-card h3 {
            font-size: 1.1rem;
            margin-bottom: 10px;
            color: #bbb;
        }
        
        .status-indicator {
            font-size: 1.5rem;
            font-weight: bold;
            margin-bottom: 10px;
        }
        
        .good {
            color: #4caf50;
        }
        
        .warning {
            color: #ff9800;
        }
        
        .error {
            color: #f44336;
        }
        
        .resource-bar {
            height: 20px;
            background: #333;
            border-radius: 10px;
            overflow: hidden;
            margin: 10px 0;
        }
        
        .progress-fill {
            height: 100%;
            border-radius: 10px;
        }
        
        .bg-success {
            background: linear-gradient(90deg, #4caf50, #8bc34a);
        }
        
        .bg-info {
            background: linear-gradient(90deg, #2196f3, #03a9f4);
        }
        
        .bg-warning {
            background: linear-gradient(90deg, #ff9800, #ffc107);
        }
        
        .bg-danger {
            background: linear-gradient(90deg, #f44336, #ff5722);
        }
        
        .section-title {
            font-size: 1.5rem;
            margin: 30px 0 20px;
            padding-bottom: 10px;
            border-bottom: 1px solid #333;
        }
        
        .containers-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .container-card {
            background: #1e1e1e;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
            transition: transform 0.3s ease;
        }
        
        .container-card:hover {
            transform: translateY(-5px);
        }
        
        .container-card h4 {
            font-size: 1.3rem;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .container-card p {
            margin: 5px 0;
            color: #bbb;
        }
        
        .status {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: bold;
        }
        
        .container-actions {
            margin-top: 15px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        
        .btn {
            padding: 8px 15px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.3s ease;
            flex: 1;
            min-width: 80px;
        }
        
        .btn-small {
            padding: 5px 10px;
            font-size: 0.9rem;
        }
        
        .btn-primary {
            background: #2196f3;
            color: white;
        }
        
        .btn-success {
            background: #4caf50;
            color: white;
        }
        
        .btn-warning {
            background: #ff9800;
            color: white;
        }
        
        .btn-danger {
            background: #f44336;
            color: white;
        }
        
        .btn-secondary {
            background: #607d8b;
            color: white;
        }
        
        .btn:hover {
            opacity: 0.9;
            transform: scale(1.05);
        }
        
        .stacks-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stack-card {
            background: #1e1e1e;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        }
        
        .stack-card h4 {
            font-size: 1.3rem;
            margin-bottom: 15px;
            color: #4fc3f7;
        }
        
        .stack-card ul {
            list-style: none;
            margin: 15px 0;
        }
        
        .stack-card li {
            padding: 5px 0;
            border-bottom: 1px solid #333;
        }
        
        .stack-card li:last-child {
            border-bottom: none;
        }
        
        .stack-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            flex-wrap: wrap;
        }
        
        .activity-feed {
            background: #1e1e1e;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 30px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        }
        
        .activity-feed h3 {
            margin-bottom: 15px;
            color: #4fc3f7;
        }
        
        .activity-feed ul {
            list-style: none;
        }
        
        .activity-feed li {
            padding: 10px 0;
            border-bottom: 1px solid #333;
            display: flex;
            justify-content: space-between;
        }
        
        .activity-feed li:last-child {
            border-bottom: none;
        }
        
        footer {
            text-align: center;
            padding: 20px;
            color: #777;
            border-top: 1px solid #333;
            margin-top: 30px;
        }
        
        @media (max-width: 768px) {
            .containers-grid {
                grid-template-columns: 1fr;
            }
            
            .status-bar {
                flex-direction: column;
                gap: 15px;
            }
            
            header {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <div class="logo">
                <i class="fas fa-server"></i>
                <h1>JenkinsNetwork Dashboard</h1>
            </div>
            <div class="status-indicator good">
                <i class="fas fa-circle"></i> All Services Operational
            </div>
        </header>
        
        <div class="status-bar">
            <div class="status-card">
                <h3>System Status</h3>
                <p class="status-indicator good">All Services Operational</p>
                <p>Uptime: 14 days, 3 hours</p>
                <p>Load Average: 0.85</p>
            </div>
            
            <div class="status-card">
                <h3>CPU Usage</h3>
                <div class="resource-bar">
                    <div class="progress-fill bg-success" style="width: 12%"></div>
                </div>
                <p>12% of 16 cores</p>
            </div>
            
            <div class="status-card">
                <h3>Memory Usage</h3>
                <div class="resource-bar">
                    <div class="progress-fill bg-info" style="width: 38%"></div>
                </div>
                <p>38% of 62GB</p>
            </div>
            
            <div class="status-card">
                <h3>Disk Usage</h3>
                <div class="resource-bar">
                    <div class="progress-fill bg-warning" style="width: 60%"></div>
                </div>
                <p>60% of 3.7TB</p>
            </div>
        </div>
        
        <h2 class="section-title">Container Status</h2>
        <div class="containers-grid">
            <% containers.forEach(container => { %>
                <div class="container-card">
                    <h4>
                        <%= container.Names[0].substring(1) %>
                        <span class="status <%= container.Status.includes('Up') ? 'good' : 'error' %>">
                            <%= container.Status.includes('Up') ? 'Running' : 'Stopped' %>
                        </span>
                    </h4>
                    <p><i class="fas fa-database"></i> <%= container.Image %></p>
                    <p><i class="fas fa-network-wired"></i> <%= container.Ports.length > 0 ? container.Ports[0].PublicPort : 'N/A' %></p>
                    <p><i class="fas fa-clock"></i> <%= container.Status %></p>
                    <div class="container-actions">
                        <button class="btn btn-small btn-success" onclick="startContainer('<%= container.Id %>')">
                            <i class="fas fa-play"></i> Start
                        </button>
                        <button class="btn btn-small btn-danger" onclick="stopContainer('<%= container.Id %>')">
                            <i class="fas fa-stop"></i> Stop
                        </button>
                        <button class="btn btn-small btn-warning" onclick="restartContainer('<%= container.Id %>')">
                            <i class="fas fa-redo"></i> Restart
                        </button>
                    </div>
                </div>
            <% }); %>
        </div>
        
        <h2 class="section-title">Service Stacks</h2>
        <div class="stacks-container">
            <div class="stack-card">
                <h4><i class="fas fa-network-wired"></i> Network Stack</h4>
                <ul>
                    <li>nginx-proxy-manager</li>
                    <li>Technitium DNS Server</li>
                    <li>SearxNG</li>
                </ul>
                <div class="stack-actions">
                    <button class="btn btn-small btn-success"><i class="fas fa-play"></i> Start</button>
                    <button class="btn btn-small btn-danger"><i class="fas fa-stop"></i> Stop</button>
                    <button class="btn btn-small btn-info"><i class="fas fa-sync"></i> Update</button>
                </div>
            </div>
            
            <div class="stack-card">
                <h4><i class="fas fa-film"></i> Media Stack</h4>
                <ul>
                    <li>Jellyfin</li>
                    <li>Navidrome</li>
                    <li>Audiobookshelf</li>
                    <li>Bazarr</li>
                    <li>Aural</li>
                    <li>Seerr</li>
                    <li>Youtarr</li>
                </ul>
                <div class="stack-actions">
                    <button class="btn btn-small btn-success"><i class="fas fa-play"></i> Start</button>
                    <button class="btn btn-small btn-danger"><i class="fas fa-stop"></i> Stop</button>
                    <button class="btn btn-small btn-info"><i class="fas fa-sync"></i> Update</button>
                </div>
            </div>
            
            <div class="stack-card">
                <h4><i class="fas fa-storage"></i> Storage Stack</h4>
                <ul>
                    <li>Immich</li>
                    <li>Vaultwarden</li>
                    <li>Gluetun</li>
                    <li>MariaDB</li>
                    <li>Valkey</li>
                    <li>Redis</li>
                    <li>Dispatcharr</li>
                </ul>
                <div class="stack-actions">
                    <button class="btn btn-small btn-success"><i class="fas fa-play"></i> Start</button>
                    <button class="btn btn-small btn-danger"><i class="fas fa-stop"></i> Stop</button>
                    <button class="btn btn-small btn-info"><i class="fas fa-sync"></i> Update</button>
                </div>
            </div>
            
            <div class="stack-card">
                <h4><i class="fas fa-download"></i> *arr* Stack</h4>
                <ul>
                    <li>Sonarr</li>
                    <li>Radarr</li>
                    <li>Lidarr</li>
                    <li>Flaresolverr</li>
                    <li>Prowlarr</li>
                </ul>
                <div class="stack-actions">
                    <button class="btn btn-small btn-success"><i class="fas fa-play"></i> Start</button>
                    <button class="btn btn-small btn-danger"><i class="fas fa-stop"></i> Stop</button>
                    <button class="btn btn-small btn-info"><i class="fas fa-sync"></i> Update</button>
                </div>
            </div>
        </div>
        
        <div class="activity-feed">
            <h3><i class="fas fa-history"></i> Recent Activity</h3>
            <ul>
                <li>
                    <span>2026-05-23 08:30:45 - Started Jellyfin container</span>
                    <span class="status-indicator good">Successful</span>
                </li>
                <li>
                    <span>2026-05-22 16:15:22 - Updated Sonarr container</span>
                    <span class="status-indicator good">Successful</span>
                </li>
                <li>
                    <span>2026-05-21 22:45:10 - System backup completed</span>
                    <span class="status-indicator good">Successful</span>
                </li>
                <li>
                    <span>2026-05-20 10:30:05 - Updated DNS configuration</span>
                    <span class="status-indicator good">Successful</span>
                </li>
                <li>
                    <span>2026-05-19 14:20:30 - MariaDB database optimized</span>
                    <span class="status-indicator good">Successful</span>
                </li>
            </ul>
        </div>
        
        <footer>
            <p>JenkinsNetwork Dashboard v1.0.0 | Last Updated: May 23, 2026</p>
        </footer>
    </div>
    
    <script>
        // Function to start a container
        function startContainer(containerId) {
            if (confirm('Are you sure you want to start this container?')) {
                // In a real implementation, you would make an API call
                console.log('Starting container:', containerId);
                alert('Container start action initiated');
            }
        }
        
        // Function to stop a container
        function stopContainer(containerId) {
            if (confirm('Are you sure you want to stop this container?')) {
                // In a real implementation, you would make an API call
                console.log('Stopping container:', containerId);
                alert('Container stop action initiated');
            }
        }
        
        // Function to restart a container
        function restartContainer(containerId) {
            if (confirm('Are you sure you want to restart this container?')) {
                // In a real implementation, you would make an API call
                console.log('Restarting container:', containerId);
                alert('Container restart action initiated');
            }
        }
        
        // Initial load message
        console.log('JenkinsNetwork Dashboard loaded successfully');
    </script>
</body>
</html>